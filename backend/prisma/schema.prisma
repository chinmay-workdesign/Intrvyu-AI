datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String             @id @default(uuid())
  email     String             @unique
  password  String
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sessions  InterviewSession[]
  analytics InterviewAnalytics?
}

model InterviewSession {
  id                 String                @id @default(uuid())
  userId             String
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               String // behavioral, technical, system_design, hr
  experienceLevel    String // junior, mid, senior, lead, staff
  resumeText         String?
  jobDescriptionText String?
  currentTopic       String                @default("")
  difficulty         Int                   @default(3) // 1 to 5
  coverage           Json                  @default("{}") // maps topics to 'not_started' | 'probing' | 'completed'
  status             String                @default("ongoing") // ongoing, completed, paused
  scores             Json                  @default("{\"communication\": 0, \"technicalDepth\": 0, \"problemSolving\": 0, \"confidence\": 0}")
  timeRemaining      Int                   @default(1200) // seconds (e.g. 20 minutes)
  messages           ConversationMessage[]
  feedbackReport     FeedbackReport?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model ConversationMessage {
  id         String           @id @default(uuid())
  sessionId  String
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker    String // INTERVIEWER, CANDIDATE
  text       String
  audioUrl   String?
  evaluation Json? // detailed evaluation if candidate message
  createdAt  DateTime         @default(now())
}

model FeedbackReport {
  id                   String           @id @default(uuid())
  sessionId            String           @unique
  session              InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallScore         Float
  communicationScore   Float
  confidenceScore      Float
  technicalDepthScore  Float
  problemSolvingScore  Float
  starFrameworkScore   Float
  leadershipScore      Float
  behavioralScore      Float
  strengths            Json // Array of strings
  weaknesses           Json // Array of strings
  areasToImprove       Json // Array of strings
  actionPlan           Json // Array of strings
  transcriptEvidence   Json // Array of { quote: string, speaker: string, evaluation: string }
  createdAt            DateTime         @default(now())
}

model InterviewAnalytics {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  averageScore  Float    @default(0.0)
  timeSpent     Int      @default(0) // total time in seconds
  sessionsCount Int      @default(0)
  scoreTrends   Json     @default("[]") // array of { date: string, score: number }
  competencies  Json     @default("{}") // maps competency name to level (0-100)
  updatedAt     DateTime @updatedAt
}
